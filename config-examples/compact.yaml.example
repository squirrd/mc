# Compaction rules for workspace cleanup
# Defines what data can be safely removed during compaction

version: 1

# Rules for identifying duplicate data
duplicates:
  # Remove downloaded attachments if they match authoritative source
  - type: attachments
    action: remove
    condition: matches_source

  # Remove case comments if they match Salesforce
  - type: case_comments
    action: remove
    condition: matches_salesforce

# Preserve user-generated content
preserve:
  # Always keep files matching these patterns
  patterns:
    - "*-notes.md"
    - "*-scratch.md"
    - "*.custom.*"

  # Keep files in these directories
  directories:
    - "files/cp"     # Customer provided files
    - "files/dp"     # Debug/diagnostic files

# Age-based cleanup
age_rules:
  # Archive old logs
  - type: logs
    age_days: 30
    action: archive

  # Remove temporary files
  - type: temp
    age_days: 7
    action: remove
