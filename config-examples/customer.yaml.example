# Customer profile example
# This file contains customer-specific configuration that applies to all cases

customer:
  name: "Example Corp"
  account_number: "1234567"
  org_id: "12345678"

# Default cluster configurations for this customer
clusters:
  - id: "cluster-001"
    type: "rosa-hcp"
    region: "us-east-1"

# Default image tag for containers (can be overridden per case)
container:
  image_tag: "latest"

# Custom mount overrides for this customer
mount_overrides: []

# Jira integration
jira:
  project: "CUSTX"
  default_labels:
    - "customer-example"
