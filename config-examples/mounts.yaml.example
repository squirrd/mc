# Mount configuration for mc containers
# This file defines how filesystems are mounted into case containers

version: 1

# Default user mappings
defaults:
  users:
    admin: 1000  # Admin user UID in container
    user: 2000   # Regular user UID in container

# Mount definitions
mounts:
  - name: system
    host: /mc/system
    container: /system
    perms:
      admin: ro    # read-only
      user: no     # not accessible

  - name: shared
    host: /mc/shared
    container: /shared
    perms:
      admin: rw    # read-write
      user: ro     # read-only

  - name: tools
    host: ~/.config/mc/tools
    container: /tools
    perms:
      admin: rw
      user: ro

  - name: case-root
    # {customer} and {case} are dynamically resolved
    host: /mc/cases/{customer}/{case}
    container: /case
    perms:
      admin: rw
      user: rw
