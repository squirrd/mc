# MC CLI Container Image - RHEL 10 UBI Base
#
# Multi-stage build optimized for layer caching and minimal runtime image size.
# Three stages: ocm-downloader (OCM binary), mc-builder (MC CLI build), final (runtime-only)
#
# Build:
#   podman build -t mc-rhel10:latest -f container/Containerfile .
#   podman build --build-arg OCM_VERSION=0.34.0 -t mc-rhel10:latest -f container/Containerfile .
#
# Run:
#   podman run --rm -it -v /path/to/workspace:/case:U mc-rhel10:latest

# =============================================================================
# Stage 1: OCM Binary Downloader
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi-minimal:latest AS ocm-downloader

# ARG for OCM version - placed before dependencies to accept build script injection (Phase 22)
# When build script injects new version via --build-arg, downstream layers are invalidated
# This is correct behavior: version changes require downloading new binary
ARG OCM_VERSION=0.35.0

# Install download tools
RUN microdnf install -y curl tar gzip && \
    microdnf clean all

# Download and verify OCM binary from GitHub releases
# Fail fast on download or checksum mismatch
RUN set -e && \
    cd /tmp && \
    curl -fsSL "https://github.com/open-component-model/ocm/releases/download/v${OCM_VERSION}/ocm-${OCM_VERSION}-linux-amd64.tar.gz" -o ocm.tar.gz && \
    curl -fsSL "https://github.com/open-component-model/ocm/releases/download/v${OCM_VERSION}/ocm-${OCM_VERSION}-linux-amd64.tar.gz.sha256" -o expected.sha256 && \
    echo "$(cat expected.sha256)  ocm.tar.gz" | sha256sum --check && \
    tar -xzf ocm.tar.gz && \
    chmod +x ocm && \
    mv ocm /usr/local/bin/ocm && \
    rm -rf /tmp/*

# =============================================================================
# Stage 2: MC CLI Builder
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi:10.1 AS mc-builder

# Install build dependencies and clean up in single layer
RUN dnf install -y \
    python3-pip \
    gcc \
    python3-devel \
    && dnf clean all && \
    rm -rf /var/cache/dnf

# Install Python build tools
RUN pip3 install --no-cache-dir setuptools wheel

# Copy project source
COPY . /opt/mc

# Install MC CLI in editable mode
# --no-cache-dir: reduces image size
# --no-build-isolation: required for editable install to work at runtime
RUN pip3 install --no-cache-dir --no-build-isolation -e /opt/mc

# =============================================================================
# Stage 3: Final Runtime Image
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi:10.1 AS final

LABEL maintainer="MC CLI Team"
LABEL description="RHEL 10 UBI container with MC CLI and essential tools for Red Hat case work"
LABEL version="2.0"

# Install runtime dependencies only (no build tools)
RUN dnf install -y \
    python3 \
    vim \
    nano \
    wget \
    openssl \
    && dnf clean all && \
    rm -rf /var/cache/dnf

# Create non-root user for security
RUN groupadd --system mcuser && \
    useradd --system --gid mcuser --home-dir /home/mcuser --create-home mcuser

# Create case workspace mount point
RUN mkdir -p /case && \
    chown mcuser:mcuser /case

# Copy OCM binary from downloader stage
COPY --from=ocm-downloader --chown=mcuser:mcuser /usr/local/bin/ocm /usr/local/bin/ocm

# Copy MC CLI source from builder stage
COPY --from=mc-builder --chown=mcuser:mcuser /opt/mc /opt/mc

# Copy Python site-packages from builder stage
COPY --from=mc-builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages

# Copy MC CLI console script from builder stage
COPY --from=mc-builder --chown=mcuser:mcuser /usr/local/bin/mc /usr/local/bin/mc

# Copy entrypoint script
COPY --chmod=755 container/entrypoint.sh /usr/local/bin/entrypoint.sh

# Set runtime mode to identify agent mode (inside container)
ENV MC_RUNTIME_MODE=agent

# Switch to non-root user
USER mcuser

# Set working directory to case workspace
WORKDIR /case

# Entrypoint handles environment initialization
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default command: interactive bash shell
CMD ["/bin/bash"]
