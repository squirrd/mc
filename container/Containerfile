# MC CLI Container Image - RHEL 10 UBI Base
#
# Multi-stage build optimized for layer caching and minimal runtime image size.
# Three stages: ocm-downloader (OCM binary), mc-builder (MC CLI build), final (runtime-only)
#
# Build:
#   podman build -t mc-rhel10:latest -f container/Containerfile .
#   podman build --build-arg OCM_VERSION=1.0.10 -t mc-rhel10:latest -f container/Containerfile .
#
# Run:
#   podman run --rm -it -v /path/to/workspace:/case:U mc-rhel10:latest

# =============================================================================
# Stage 1: OCM Binary Downloader
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi-minimal:latest AS ocm-downloader

# ARG for OCM version - placed before dependencies to accept build script injection (Phase 22)
# When build script injects new version via --build-arg, downstream layers are invalidated
# This is correct behavior: version changes require downloading new binary
ARG OCM_VERSION=1.0.10

# Install download tools
RUN microdnf install -y curl tar gzip && \
    microdnf clean all

# Download and verify OCM binary from GitHub releases
# Fail fast on download or checksum mismatch
RUN set -e && \
    cd /tmp && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then ARCH="amd64"; elif [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi && \
    curl -fsSL "https://github.com/openshift-online/ocm-cli/releases/download/v${OCM_VERSION}/ocm-linux-${ARCH}" -o ocm-linux-${ARCH} && \
    curl -fsSL "https://github.com/openshift-online/ocm-cli/releases/download/v${OCM_VERSION}/ocm-linux-${ARCH}.sha256" -o ocm-linux-${ARCH}.sha256 && \
    sha256sum --check ocm-linux-${ARCH}.sha256 && \
    chmod +x ocm-linux-${ARCH} && \
    mv ocm-linux-${ARCH} /usr/local/bin/ocm && \
    rm -rf /tmp/*

# =============================================================================
# Stage 2: backplane Binary Downloader
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi-minimal:latest AS backplane-downloader

# ARG for backplane version - placed before dependencies to accept build script injection (Phase 22)
# When build script injects new version via --build-arg, downstream layers are invalidated
# This is correct behavior: version changes require downloading new binary
ARG BACKPLANE_VERSION=0.7.0

# Install download tools
RUN microdnf install -y curl tar gzip && \
    microdnf clean all

# Download and verify backplane binary from GitHub releases
# Fail fast on download or checksum mismatch
RUN set -e && \
    cd /tmp && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi && \
    TARBALL="ocm-backplane_${BACKPLANE_VERSION}_Linux_${ARCH}.tar.gz" && \
    curl -fsSL "https://github.com/openshift/backplane-cli/releases/download/v${BACKPLANE_VERSION}/${TARBALL}" -o "${TARBALL}" && \
    curl -fsSL "https://github.com/openshift/backplane-cli/releases/download/v${BACKPLANE_VERSION}/checksums.txt" -o checksums.txt && \
    grep "${TARBALL}" checksums.txt | sha256sum --check && \
    tar --no-same-owner -xzf "${TARBALL}" && \
    chmod +x ocm-backplane && \
    mv ocm-backplane /usr/local/bin/ocm-backplane && \
    rm -rf /tmp/*

# =============================================================================
# Stage 3: OC CLI Downloader
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi-minimal:latest AS oc-downloader

# ARG for OC version - uses "latest" by default to always get current stable release
# Can be overridden to specific version like "4.21.1" via --build-arg OC_VERSION=4.21.1
ARG OC_VERSION=latest

# Install download tools
RUN microdnf install -y curl tar gzip && \
    microdnf clean all

# Download and verify oc binary from OpenShift mirror
# Fail fast on download or checksum mismatch
RUN set -e && \
    cd /tmp && \
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then \
        TARBALL="openshift-client-linux.tar.gz"; \
    elif [ "$ARCH" = "aarch64" ]; then \
        TARBALL="openshift-client-linux-arm64.tar.gz"; \
    else \
        echo "Unsupported architecture: ${ARCH}" && exit 1; \
    fi && \
    curl -fsSL "https://mirror.openshift.com/pub/openshift-v4/clients/ocp/${OC_VERSION}/${TARBALL}" -o "${TARBALL}" && \
    curl -fsSL "https://mirror.openshift.com/pub/openshift-v4/clients/ocp/${OC_VERSION}/sha256sum.txt" -o sha256sum.txt && \
    grep "${TARBALL}" sha256sum.txt | sha256sum --check && \
    tar --no-same-owner -xzf "${TARBALL}" && \
    chmod +x oc kubectl && \
    mv oc /usr/local/bin/oc && \
    mv kubectl /usr/local/bin/kubectl && \
    rm -rf /tmp/*

# =============================================================================
# Stage 4: MC CLI Builder
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi:10.1 AS mc-builder

# Accept SOURCE_DATE_EPOCH for reproducible builds (from build script)
ARG SOURCE_DATE_EPOCH=1704067200

# Install build dependencies and clean up in single layer
RUN dnf install -y \
    python3-pip \
    gcc \
    python3-devel \
    && dnf clean all && \
    rm -rf /var/cache/dnf

# Install Python build tools with reproducible bytecode
# SOURCE_DATE_EPOCH makes .pyc timestamp deterministic
RUN SOURCE_DATE_EPOCH=${SOURCE_DATE_EPOCH} pip3 install --no-cache-dir setuptools wheel

# Copy project source
COPY . /opt/mc

# Install MC CLI in editable mode with reproducible bytecode
# --no-cache-dir: reduces image size
# --no-build-isolation: required for editable install to work at runtime
# SOURCE_DATE_EPOCH: makes Python bytecode (.pyc files) deterministic
RUN SOURCE_DATE_EPOCH=${SOURCE_DATE_EPOCH} pip3 install --no-cache-dir --no-build-isolation -e /opt/mc

# =============================================================================
# Stage 5: Final Runtime Image
# =============================================================================
FROM registry.access.redhat.com/ubi10/ubi:10.1 AS final

LABEL maintainer="MC CLI Team"
LABEL description="RHEL 10 UBI container with MC CLI and essential tools for Red Hat case work"
LABEL version="2.0"

# Install runtime dependencies only (no build tools)
RUN dnf install -y \
    python3 \
    vim \
    nano \
    wget \
    openssl \
    less \
    && dnf clean all && \
    rm -rf /var/cache/dnf

# Create non-root user for security
RUN groupadd --system mcuser && \
    useradd --system --gid mcuser --home-dir /home/mcuser --create-home mcuser

# Create case workspace mount point
RUN mkdir -p /case && \
    chown mcuser:mcuser /case

# Copy OCM binary from downloader stage
COPY --from=ocm-downloader --chown=mcuser:mcuser /usr/local/bin/ocm /usr/local/bin/ocm

# Copy backplane binary from downloader stage
COPY --from=backplane-downloader --chown=mcuser:mcuser /usr/local/bin/ocm-backplane /usr/local/bin/ocm-backplane

# Copy oc and kubectl binaries from downloader stage
COPY --from=oc-downloader --chown=mcuser:mcuser /usr/local/bin/oc /usr/local/bin/oc
COPY --from=oc-downloader --chown=mcuser:mcuser /usr/local/bin/kubectl /usr/local/bin/kubectl

# Copy MC CLI source from builder stage
COPY --from=mc-builder --chown=mcuser:mcuser /opt/mc /opt/mc

# Copy Python site-packages from builder stage
COPY --from=mc-builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages

# Copy MC CLI console script from builder stage
COPY --from=mc-builder --chown=mcuser:mcuser /usr/local/bin/mc /usr/local/bin/mc

# Copy entrypoint script
COPY --chmod=755 container/entrypoint.sh /usr/local/bin/entrypoint.sh

# Set runtime mode to identify agent mode (inside container)
ENV MC_RUNTIME_MODE=agent

# Switch to non-root user
USER mcuser

# Set working directory to case workspace
WORKDIR /case

# Entrypoint handles environment initialization
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default command: interactive bash shell
CMD ["/bin/bash"]
